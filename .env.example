# ===========================
# PreGrade Environment Config
# ===========================
# Copy this file to backend/.env and fill in your values.
# NEVER commit the .env file with real secrets.

# ── Database ──────────────────────────────────────────────
# Option A: Supabase (cloud)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"

# Option B: Local PostgreSQL (via docker-compose up -d)
# DATABASE_URL="postgresql://pregrade:pregrade@localhost:5433/pregrade?schema=public"
# DIRECT_URL="postgresql://pregrade:pregrade@localhost:5433/pregrade?schema=public"

# ── Authentication ────────────────────────────────────────
JWT_SECRET="CHANGE_ME_IN_PRODUCTION_use_a_random_64char_string"

# ── AI Provider ───────────────────────────────────────────
# Default: Groq (free tier -- get key at https://console.groq.com)
AI_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Alternative: OpenAI
# AI_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# ── AI Tuning ─────────────────────────────────────────────
AI_TEMPERATURE=0.2
AI_PROMPT_VERSION=1.0.0

# ── Server ────────────────────────────────────────────────
PORT=3002
NODE_ENV=development
LOG_LEVEL=info
